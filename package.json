{
  "name": "diva-client",
  "license": "GPL-3.0",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "BASE_PATH=/@BASENAME@ react-router build",
    "dev": "npm run typegen && NODE_ENV=development tsx server.ts | pino-pretty",
    "prestart": "node scripts/prestart.js",
    "start": "npm run prestart && tsx server.ts",
    "typegen": "tsx typegen/main.ts",
    "typecheck": "react-router typegen && tsc",
    "typecheck:w": "react-router typegen && tsc -w",
    "stylelint": "stylelint ./app/**/**/*.{css,scss}",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier-format": "prettier --write \"src/**/*.{ts,tsx,json}\" --config ./.prettierrc.json",
    "test": "vitest --silent=true",
    "test:ci": "vitest run --reporter=junit --reporter=default --outputFile=./junit-report.xml",
    "test:ui": "vitest --ui",
    "coverage": "vitest --coverage"
  },
  "engines": {
    "node": "25.9.0"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.1.1",
    "@react-router/express": "^7.18.0",
    "@react-router/node": "^7.18.0",
    "@uiw/react-codemirror": "^4.25.8",
    "amqplib": "^0.10.9",
    "axios": "1.16.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^4.0.0",
    "isbot": "^5.1.44",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "remix-hook-form": "^7.1.0",
    "sass": "^1.101.0",
    "tsx": "^4.20.6",
    "yup": "^1.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@faker-js/faker": "^10.3.0",
    "@react-router/dev": "^7.18.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/amqplib": "^0.10.8",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.8",
    "axios-mock-adapter": "^2.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.0",
    "eslint-plugin-jsx-a11y": "^6.10.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^8.1.0",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.0.8",
    "vitest-mock-extended": "^3.1.0"
  }
}
